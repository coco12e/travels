<% bookmark = trip.bookmarks.find_by(place: place) %>
<% if bookmark %>
  <%= button_to "Désélectionner", trip_bookmark_path(trip, bookmark),
        method: :delete,
        class: "btn px-4 fw-bold shadow-sm text-white",
        style: "background-color: #555; border: none; border-radius: 5px;" %>
<% else %>
  <%= button_to "Sélectionner", trip_bookmarks_path(trip, place_id: place.id),
        method: :post,
        class: "btn px-4 fw-bold shadow-sm text-white",
        style: "background-color: #d35400; border: none; border-radius: 5px;" %>
<% end %>
