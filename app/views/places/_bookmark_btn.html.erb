<% bookmark = trip.bookmarks.find_by(place: place) %>

<% if bookmark %>
  <%= button_to trip_bookmark_path(trip, bookmark),
        method: :delete,
        params: { return_to: params[:return_to] },
        data: { turbo: false },
        class: "btn p-0 border-0 bg-transparent" do %>
    <div class="d-flex align-items-center gap-2">
      <div style="width: 20px; height: 20px; border-radius: 50%; border: 2px solid #27ae60; display: flex; align-items: center; justify-content: center; background: white;">
        <div style="width: 10px; height: 10px; border-radius: 50%; background: #27ae60;"></div>
      </div>
      <span style="font-size: 13px; color: #27ae60; font-weight: 500;">Sélectionné</span>
    </div>
  <% end %>
<% else %>
  <%= button_to trip_bookmarks_path(trip),
        method: :post,
        params: { place_id: place.id, return_to: params[:return_to] },
        data: { turbo: false },
        class: "btn p-0 border-0 bg-transparent" do %>
    <div class="d-flex align-items-center gap-2">
      <div style="width: 20px; height: 20px; border-radius: 50%; border: 2px solid #d35400; background: white;"></div>
      <span style="font-size: 13px; color: #d35400;">Sélectionner</span>
    </div>
  <% end %>
<% end %>
