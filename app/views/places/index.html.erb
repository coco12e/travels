<%
  current_step = case @category&.name
  when "La Capitale et les marchés traditionnels" then 2
  when "Les autres Villes"                        then 3
  when "Les Stations Balnéaires"                  then 4
  when "Les Hors circuits"                        then 5
  when "Les déserts et le Nil"                    then 6
  when "Les plats typiques"                       then 7
  else 2
  end
%>
<%= render "shared/stepper", current_step: current_step %>

<div class="container-fluid px-5 py-5" style="background-color: #f0f2f5;">
  <div class="mb-5">
    <h1 class="display-4 fw-bold mb-4" style="color: #070485;">
      <%= @category&.name %>
    </h1>
    <div class="fs-5 text-dark">
      <% case @category&.name %>
      <% when /Capitale/ %>
        <p class="m-0">Cette section invite les voyageurs à découvrir les paysages emblématiques et les trésors architecturaux qui jalonnent la vallée du Nil au cœur de la capitale égyptienne.</p>
      <% when "Les autres Villes" %>
        <p class="m-0">Cette section invite les voyageurs à découvrir les paysages emblématiques et les trésors architecturaux qui jalonnent la vallée du Nil et le littoral méditerranéen.</p>
      <% when "Les Stations Balnéaires" %>
        <p class="m-0">Cette section propose des expériences uniques pour les voyageurs souhaitant s'éloigner des parcours classiques et découvrir des paysages naturels spectaculaires, tant sur la mer Rouge que sur la Méditerranée.</p>
      <% when "Les Hors circuits" %>
        <p class="m-0">Cette section propose des expériences uniques pour les voyageurs souhaitant s'éloigner des parcours classiques et découvrir des paysages naturels spectaculaires ainsi que des cultures locales préservées.</p>
      <% when "Les déserts et le Nil" %>
        <p class="m-0">Cette section invite à découvrir les paysages emblématiques de l'Égypte, entre l'immensité aride du désert et la vie foisonnante des bords du Nil.</p>
      <% else %>
        <p class="m-0">La gastronomie égyptienne offre des saveurs authentiques, allant de plats complets et nourrissants à des douceurs parfumées.</p>
      <% end %>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <% @places.group_by(&:sub_category).each do |sub_cat_name, places| %>
        <% if sub_cat_name.present? %>
          <h2 class="fw-bold mb-4 mt-5" id="<%= sub_cat_name.parameterize %>" style="color: #070485;">
            <%= places.size == 1 ? sub_cat_name.gsub("Les activités", "L'activité") : sub_cat_name %>
          </h2>
        <% end %>

        <% if @category&.name == "Les plats typiques" %>
          <div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
            <% places.each do |place| %>
              <div class="col">
                <div class="card h-100 shadow-sm border-0" id="place-<%= place.id %>">
                  <% if place.photo_url.present? %>
                    <img src="/images/<%= place.photo_url.strip %>" class="card-img-top" alt="<%= place.name %>" style="object-fit: contain; background: #f8f8f8;">
                  <% else %>
                    <div style="height: 200px; background: #eee; display: flex; align-items: center; justify-content: center;">
                      <i class="fa-solid fa-image text-secondary fs-1 opacity-25"></i>
                    </div>
                  <% end %>
                  <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold" style="color: #070485; font-size: 1.3rem;"><%= place.name %></h5>
                    <p class="card-text text-dark" style="font-size: 1rem; flex: 1;"><%= place.description&.squish %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

        <% else %>
          <% places.each do |place| %>
            <div id="place-<%= place.id %>" class="mb-4 rounded-3 shadow-sm bg-white" style="display: flex; overflow: hidden;">

              <%# IMAGE %>
              <div style="width: 350px; min-width: 350px; min-height: 220px; position: relative; overflow: hidden;">
                <% if place.photo_url.present? %>
                  <img src="/images/<%= place.photo_url.strip %>" alt="<%= place.name %>"
                       style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; object-position: center;">
                <% else %>
                  <div style="width: 100%; height: 100%; min-height: 220px; background: #eee; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-image text-secondary fs-1 opacity-25"></i>
                  </div>
                <% end %>
              </div>

              <%# CONTENU %>
              <div style="flex: 1; padding: 20px; display: flex; flex-direction: column; justify-content: space-between;">
                <div>
                  <h4 style="color: #070485; font-weight: 700; margin-bottom: 6px; font-size: 1.5rem;"><%= place.name %></h4>
                  <% if place.address.present? %>
                    <p style="color: #888; font-size: 1.1rem; margin-bottom: 10px;">
                      <i class="fa-solid fa-location-dot me-1" style="color: #d35400;"></i>
                      <%= place.address %>
                    </p>
                  <% end %>
                  <p style="font-size: 1.25rem; color: #333;"><%= place.description&.squish %></p>
                </div>
                <div style="display: flex; justify-content: flex-end;" id="bookmark-btn-<%= place.id %>">
                  <%= render "places/bookmark_btn", place: place, trip: @trip, return_to: params[:return_to] %>
                </div>
              </div>

            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<% categories = Category.order(:id).to_a %>
<% current_index = categories.index(@category) %>
<% prev_category = categories[current_index - 1] if current_index > 0 %>
<% next_category = categories[current_index + 1] %>

<footer style="width: 100%; padding: 12px 24px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center;">
  <% if prev_category %>
    <%= link_to "← #{prev_category.name}", trip_category_places_path(@trip, prev_category),
          class: "btn fw-semibold px-4",
          style: "color: white; border: 0; background-color: #d35400;" %>
  <% else %>
    <%= link_to "← Les catégories", trip_categories_path(@trip),
          class: "btn fw-semibold px-4",
          style: "color: white; border: 0; background-color: #d35400;" %>
  <% end %>

  <% if next_category %>
    <%= link_to "#{next_category.name} →", trip_category_places_path(@trip, next_category),
          class: "btn fw-semibold px-4",
          style: "color: white; border: 0; background-color: #d35400;" %>
  <% else %>
    <%= link_to "Les transports →", trip_transports_path(@trip),
          class: "btn fw-semibold px-4",
          style: "color: white; border: 0; background-color: #d35400;" %>
  <% end %>
</footer>
