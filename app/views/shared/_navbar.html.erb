<nav class="navbar navbar-expand-lg bg-white shadow-sm">
  <div class="container-fluid px-4">

    <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 fw-bold" do %>
      <i class="fa-solid fa-plane-departure fs-4" style="color: #070485;"></i>
      <span style="color: #070485;">Travel</span>
    <% end %>

    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav ms-auto align-items-center gap-2">

        <li class="nav-item">
          <%= link_to "Accueil", root_path, class: "nav-link fw-semibold" %>
        </li>

        <li class="nav-item">
          <%= link_to "Destinations", destinations_path(continent: "Moyen-Orient"), class: "nav-link fw-semibold" %>
        </li>

        <% if @egypte && !@hide_egypte_nav %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle fw-semibold" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              L'Égypte Explorer
            </a>
            <ul class="dropdown-menu shadow border-0 bg-white">
              <li><%= link_to "L'Égypte Explorer", destination_path(@egypte), class: "dropdown-item fw-bold" %></li>
              <li><hr class="dropdown-divider"></li>
              <% if user_signed_in? %>
                <% if @navbar_trip %>
                  <li><%= link_to "Les Vols", trip_flights_path(@navbar_trip), class: "dropdown-item #{'active-link' if controller_name == 'flights'}" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to "Explorer les catégories", trip_categories_path(@navbar_trip), class: "dropdown-item #{'active-link' if controller_name == 'categories'}" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to "Transports : Pays et villes", trip_transports_path(@navbar_trip), class: "dropdown-item #{'active-link' if controller_name == 'transports'}" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= link_to "Récapitulatif", trip_path(@navbar_trip), class: "dropdown-item #{'active-link' if controller_name == 'trips' && action_name == 'show'}" %></li>
                <% else %>
                  <li><span class="dropdown-item text-muted">Aucun voyage en cours</span></li>
                <% end %>
              <% end %>
            </ul>
          </li>

          <% if @show_categories_nav && user_signed_in? && @navbar_trip %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle fw-semibold" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Les catégories
              </a>
              <ul class="dropdown-menu shadow border-0 dropdown-menu-end bg-white" style="min-width: 320px;">
                <li><%= link_to "Les catégories", trip_categories_path(@navbar_trip), class: "dropdown-item fw-bold" %></li>
                <li><hr class="dropdown-divider"></li>
                <% @egypte.categories.order(:id).each do |cat| %>
                  <li><%= link_to cat.name, trip_category_places_path(@navbar_trip, cat), class: "dropdown-item #{'active-link' if @category&.id == cat.id}" %></li>
                  <li><hr class="dropdown-divider"></li>
                <% end %>
              </ul>
            </li>
          <% end %>
        <% end %>

        <% if user_signed_in? %>
          <li class="nav-item">
            <%= button_to "Se déconnecter", destroy_user_session_path, method: :delete, class: "nav-link fw-semibold text-dark border-0 bg-transparent" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Connexion", new_user_session_path, class: "nav-link fw-semibold" %>
          </li>
        <% end %>

      </ul>
    </div>
  </div>
</nav>
