<div class="container-fluid py-4 px-5 bg-light">

  <div class="mb-4 text-start">
    <h1 class="fw-bold mb-3" style="color: #070485;">Égypte Explorer</h1>
    <h2 class="fs-4" style="color: #019dbd;">Découvre l'Égypte comme jamais auparavant !</h2>
  </div>

  <div class="row mb-5">
    <div class="col-12">
      <p class="mb-0 fs-5 lh-lg" style="color: #333;">
        Égypte Explorer est l'outil conçu pour ceux qui refusent les voyages organisés.
        Construisez votre aventure par vos propres moyens en maîtrisant chaque étape.
      </p>
    </div>
  </div>

  <div class="row mb-5">
    <div class="col-12">
      <img src="/egypt.png" class="img-fluid w-100 rounded shadow" alt="Égypte Panorama">
    </div>
  </div>

  <h3 class="text-center mb-5 fw-bold" style="color: #070485;">Construire votre aventure étape par étape</h3>

  <div class="row g-4 justify-content-center">

    <div class="col-md-4">
      <div class="card h-100 border-0 bg-light shadow-sm overflow-hidden">
        <div class="ratio ratio-16x9">
          <img src="/avion.jpg" class="card-img-top object-fit-cover" alt="Vols">
        </div>
        <div class="card-body d-flex flex-column">
          <h5 class="card-title fw-bold" style="color: #070485;">Les Vols</h5>
          <div class="mt-auto text-end">
            <% if @trip %>
              <%= link_to "Sélectionner", trip_flights_path(@trip), class: "btn shadow-sm px-4 text-white fw-bold border-0 rounded-2", style: "background-color: #d35400;" %>
            <% else %>
              <%= button_to "Sélectionner", trips_path, params: { trip: { destination_id: @destination.id }, next_step: "flights" }, method: :post, class: "btn shadow-sm px-4 text-white fw-bold border-0 rounded-2", style: "background-color: #d35400;" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 bg-light shadow-sm overflow-hidden">
        <div class="ratio ratio-16x9">
          <img src="/explorer-categories.jpg" class="card-img-top object-fit-cover" alt="Catégories">
        </div>
        <div class="card-body d-flex flex-column">
          <h5 class="card-title fw-bold" style="color: #070485;">Explorer les catégories</h5>
          <div class="mt-auto text-end">
            <% if @trip %>
              <%= link_to "Sélectionner", trip_categories_path(@trip), class: "btn shadow-sm px-4 text-white fw-bold border-0 rounded-2", style: "background-color: #d35400;" %>
            <% else %>
              <%= button_to "Sélectionner", trips_path, params: { trip: { destination_id: @destination.id }, next_step: "categories" }, method: :post, class: "btn shadow-sm px-4 text-white fw-bold border-0 rounded-2", style: "background-color: #d35400;" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 border-0 bg-light shadow-sm overflow-hidden">
        <div class="ratio ratio-16x9">
          <img src="/transports.jpg" class="card-img-top object-fit-cover" alt="Transports">
        </div>
        <div class="card-body d-flex flex-column">
          <h5 class="card-title fw-bold" style="color: #070485;">Transports : Pays et villes</h5>
          <div class="mt-auto text-end">
            <% if @trip %>
              <%= link_to "Sélectionner", trip_transports_path(@trip), class: "btn shadow-sm px-4 text-white fw-bold border-0 rounded-2", style: "background-color: #d35400;" %>
            <% else %>
              <%= button_to "Sélectionner", trips_path, params: { trip: { destination_id: @destination.id }, next_step: "transports" }, method: :post, class: "btn shadow-sm px-4 text-white fw-bold border-0 rounded-2", style: "background-color: #d35400;" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mt-4 align-items-center">
    <div class="col-md-3 d-none d-md-block">
      <img src="/hurghada.jpg" class="img-fluid rounded shadow-sm object-fit-cover" style="height: 250px; width: 100%;">
    </div>

    <div class="col-md-6">
      <div class="card border-0 bg-light shadow-sm overflow-hidden">
        <div class="ratio ratio-16x9">
          <img src="/Louxor.jpg" class="card-img-top object-fit-cover" alt="Récapitulatif">
        </div>
        <div class="card-body d-flex flex-column">
          <h5 class="card-title fw-bold" style="color: #070485;">Récapitulatif</h5>
          <div class="mt-auto text-end">
            <% if @trip %>
              <%= link_to "Sélectionner", trip_path(@trip), class: "btn shadow-sm px-4 text-white fw-bold border-0 rounded-2", style: "background-color: #d35400;" %>
            <% else %>
              <%= button_to "Sélectionner", trips_path, params: { trip: { destination_id: @destination.id }, next_step: "show" }, method: :post, class: "btn shadow-sm px-4 text-white fw-bold border-0 rounded-2", style: "background-color: #d35400;" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-3 d-none d-md-block">
      <img src="/siwa.jpg" class="img-fluid rounded shadow-sm object-fit-cover" style="height: 250px; width: 100%;">
    </div>
  </div>

</div>
