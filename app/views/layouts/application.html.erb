<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Travels" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Travels">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </head>
  <body>
    <%= render "shared/navbar" %>
    <%= render "shared/flashes" %>
    <div id="page-content">
      <%= yield %>
    </div>

    <% if controller_name == 'destinations' && action_name == 'show' %>
      <footer style="background-color: #f8f9fa; border-top: 1px solid #dee2e6; padding: 20px 60px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; align-items: start;">
          <div>
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Destination</p>
            <p style="color: #555; font-size: 0.85rem; margin: 0;"><strong>L'Égypte</strong> : Explorez les merveilles de l'Égypte ancienne et moderne à votre rythme.</p>
          </div>
          <div class="text-center">
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Égypte Explorer</p>
            <div class="d-flex gap-3 justify-content-center" style="color: #555; font-size: 0.85rem;">
              <span>Les vols</span>
              <span>Les catégories</span>
              <span>Les transports</span>
              <span>Le récapitulatif</span>
            </div>
          </div>
          <div class="text-end">
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Suivez-nous</p>
            <div class="d-flex gap-2 justify-content-end" style="font-size: 1.2rem; color: #555;">
              <i class="fa-brands fa-facebook"></i>
              <i class="fa-brands fa-instagram"></i>
            </div>
          </div>
        </div>
        <div class="text-center mt-3" style="color: #999; font-size: 0.8rem;">
          &copy; <%= Time.now.year %> Travels. Tous droits réservés.
        </div>
      </footer>

    <% elsif controller_name == 'pages' && action_name == 'home' %>
      <footer style="background-color: #f8f9fa; border-top: 1px solid #dee2e6; padding: 20px 60px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; align-items: start;">
          <div>
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Travel</p>
            <p style="color: #555; font-size: 0.85rem; margin: 0;">Préparez votre voyage pour explorer le monde à votre rythme.</p>
          </div>
          <div class="text-center">
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Continents</p>
            <p style="color: #555; font-size: 0.85rem; margin: 0;">Moyen-Orient · Europe · Afrique · Asie · Amérique · Océanie</p>
          </div>
          <div class="text-end">
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Suivez-nous</p>
            <div class="d-flex gap-2 justify-content-end" style="font-size: 1.2rem; color: #555;">
              <i class="fa-brands fa-facebook"></i>
              <i class="fa-brands fa-instagram"></i>
            </div>
          </div>
        </div>
        <div class="text-center mt-3" style="color: #999; font-size: 0.8rem;">
          &copy; <%= Time.now.year %> Travels. Tous droits réservés.
        </div>
      </footer>

    <% elsif controller_name == 'destinations' && action_name == 'index' %>
      <footer style="background-color: #f8f9fa; border-top: 1px solid #dee2e6; padding: 20px 60px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; align-items: start;">
          <div>
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Travel</p>
            <p style="color: #555; font-size: 0.85rem; margin: 0;">Découvrez les pays du Moyen-Orient et planifiez votre aventure.</p>
          </div>
          <div class="text-center">
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Destinations</p>
            <p style="color: #555; font-size: 0.85rem; margin: 0;">L'Égypte · Jordanie · Émirats Arabes Unis · L'Arabie Saoudite · Le Liban · Chypre · Qatar · Turquie · Oman</p>
          </div>
          <div class="text-end">
            <p class="fw-bold mb-2" style="color: #070485; font-size: 0.9rem;">Suivez-nous</p>
            <div class="d-flex gap-2 justify-content-end" style="font-size: 1.2rem; color: #555;">
              <i class="fa-brands fa-facebook"></i>
              <i class="fa-brands fa-instagram"></i>
            </div>
          </div>
        </div>
        <div class="text-center mt-3" style="color: #999; font-size: 0.8rem;">
          &copy; <%= Time.now.year %> Travels. Tous droits réservés.
        </div>
      </footer>
    <% end %>

  </body>
</html>
