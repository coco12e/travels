<div class="mb-5">
  <div class="border border-dark bg-white shadow-sm">
    <div class="row g-0 align-items-stretch">

      <%# Colonne logos compagnies %>
      <div class="col-3 border-end border-dark bg-light d-flex flex-column justify-content-center align-items-center p-3" style="min-height: 190px;">
        <% if flight.company == flight.company_return %>
          <% if flight.photo.present? %>
            <img src="/assets/<%= flight.photo %>" class="img-fluid" style="max-height: 100px; object-fit: contain;">
          <% else %>
            <span class="fw-bold text-muted text-uppercase"><%= flight.company %></span>
          <% end %>
        <% else %>
          <div class="w-100 text-center pb-3 border-bottom border-dark mb-3">
            <% if flight.photo.present? %>
              <img src="/assets/<%= flight.photo %>" class="img-fluid" style="max-height: 60px; object-fit: contain;">
            <% end %>
          </div>
          <div class="w-100 text-center">
            <% if flight.photo_return.present? %>
              <img src="/assets/<%= flight.photo_return %>" class="img-fluid" style="max-height: 60px; object-fit: contain;">
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Colonne aller / retour %>
      <div class="col-9">

        <%# Ligne Aller %>
        <div class="row g-0 border-bottom border-dark align-items-center" style="min-height: 95px;">
          <div class="col-2 border-end border-dark d-flex align-items-center justify-content-center fw-bold h-100 bg-white fs-5">Aller</div>
          <div class="col-10 px-4">
            <div class="d-flex align-items-center justify-content-between w-100">
              <span class="fw-bold fs-4"><%= flight.take_off_at %></span>
              <div class="flex-grow-1 mx-5 text-center">
                <div class="fw-bold mb-1"><%= flight.company %></div>
                <%= render "trips/flight_arrow" %>
                <div class="text-muted small">
                  <%= flight.duration %> de vol
                  <% if flight.stopover.present? && !["Direct", "0", ""].include?(flight.stopover) %>
                    et <%= flight.stopover %>
                  <% end %>
                </div>
              </div>
              <span class="fw-bold fs-4"><%= flight.land_at %></span>
            </div>
          </div>
        </div>

        <%# Ligne Retour %>
        <div class="row g-0 align-items-center" style="min-height: 95px;">
          <div class="col-2 border-end border-dark d-flex align-items-center justify-content-center fw-bold h-100 bg-white fs-5">Retour</div>
          <div class="col-10 px-4">
            <div class="d-flex align-items-center justify-content-between w-100">
              <span class="fw-bold fs-4"><%= flight.take_off_at_return %></span>
              <div class="flex-grow-1 mx-5 text-center">
                <div class="fw-bold mb-1"><%= flight.company_return %></div>
                <%= render "trips/flight_arrow" %>
                <div class="text-muted small">
                  <%= flight.duration_return %> de vol
                  <% if flight.stopover_return.present? && !["Direct", "0", ""].include?(flight.stopover_return) %>
                    et <%= flight.stopover_return %>
                  <% end %>
                </div>
              </div>
              <span class="fw-bold fs-4"><%= flight.land_at_return %></span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <%# Bouton Sélectionner / Désélectionner %>
  <div class="mt-2 d-flex justify-content-end">
    <% if trip.flight_id == flight.id %>
      <%= button_to "Désélectionner", unselect_flight_trip_path(trip),
            method: :patch,
            data: { turbo: false },
            class: "btn px-4 fw-bold shadow-sm text-white border-0 rounded-2",
            style: "background-color: #27ae60;" %>
    <% else %>
      <%= button_to "Sélectionner", select_flight_trip_path(trip, flight_id: flight.id),
            method: :patch,
            data: { turbo: false },
            class: "btn px-4 fw-bold shadow-sm text-white border-0 rounded-2",
            style: "background-color: #d35400;" %>
    <% end %>
  </div>
</div>
