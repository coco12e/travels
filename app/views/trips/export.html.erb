<div class="container-fluid px-5 py-5">
  <div class="mb-5">
    <h1 class="display-4 fw-bold mb-3" style="color: #070485;">Le récapitulatif complet</h1>
    <p class="text-dark w-100" style="line-height: 1.6; font-size: 1.1rem;">
      Le récapitulatif complet est la page de synthèse qui permet de visualiser l'ensemble de l'aventure que vous avez construite.
      Cet outil est conçu pour offrir une maîtrise totale de votre itinéraire avant le départ.
    </p>
  </div>

  <div class="card shadow-sm" style="border: 1px solid #000;">
    <div class="card-header bg-white text-center py-4" style="border-bottom: 1px solid #000;">
      <h2 class="fw-bold mb-0" style="color: #000;">Résumé du voyage</h2>
    </div>

    <div class="card-body p-0">
      <table class="table table-bordered mb-0 align-middle" style="border: 1px solid #000; border-collapse: collapse; width: 100%;">
        <tbody>

          <tr style="border-bottom: 1px solid #000;">
            <td class="fw-bold px-4" style="width: 25%; border-right: 1px solid #000;">Les vols pour se rendre en Égypte</td>
            <td class="px-4" style="width: 75%;">
              <% if @trip.flight %>
                <div>
                  <strong><%= @trip.flight.company %></strong> — Aller : <%= @trip.flight.take_off_at %> → <%= @trip.flight.land_at %>
                  <span class="text-muted small">(<%= @trip.flight.stopover.present? ? @trip.flight.stopover : "direct" %>)</span>
                </div>
                <div>
                  <strong><%= @trip.flight.company_return %></strong> — Retour : <%= @trip.flight.take_off_at_return %> → <%= @trip.flight.land_at_return %>
                  <span class="text-muted small">(<%= @trip.flight.stopover_return.present? ? @trip.flight.stopover_return : "direct" %>)</span>
                </div>
              <% else %>
                <span class="text-muted">Aucun vol sélectionné</span>
              <% end %>
            </td>
          </tr>

          <%
            categories_mapping = {
              "La Capitale et les marchés traditionnels" => nil,
              "Les autres Villes" => ["Alexandrie", "Assouan", "Louxor"],
              "Les Stations Balnéaires" => ["Sharm el-Sheikh", "Marsa Matrouh", "Hurghada", "Marsa Alam", "Taba", "Nuweiba"],
              "Les Hors circuits" => ["Fayoum", "Le village nubiens", "Oasis"],
              "Les déserts et le Nil" => ["déserts", "Nil"]
            }
          %>

          <% categories_mapping.each do |cat_name, sous_elements| %>
            <% category = Category.find_by(name: cat_name) %>
            <% if category %>
              <tr><td colspan="2" class="text-center fw-bold py-2 bg-light" style="border-bottom: 1px solid #000;"><%= cat_name %></td></tr>

              <% if sous_elements.nil? %>
                <tr style="border-bottom: 1px solid #000;">
                  <td class="fw-bold px-4" style="border-right: 1px solid #000;">Activités</td>
                  <td class="px-4">
                    <% places = @trip.bookmarks.joins(:place).where(places: { category_id: category.id }).map(&:place) %>
                    <% if places.any? %>
                      <% places.each do |place| %><div><strong><%= place.name %></strong></div><% end %>
                    <% else %>
                      <span class="text-muted">Aucune activité sélectionnée</span>
                    <% end %>
                  </td>
                </tr>
              <% else %>
                <% sous_elements.each do |elem| %>
                  <tr style="border-bottom: 1px solid #000;">
                    <td class="px-4" style="border-right: 1px solid #000;"><strong><%= elem %></strong></td>
                    <td class="px-4">
                      <% search_term = elem.length > 5 ? elem.first(7) : elem.first(4) %>
                      <% places = @trip.bookmarks.joins(:place)
                                       .where(places: { category_id: category.id })
                                       .where("places.sub_category ILIKE ?", "%#{search_term}%")
                                       .map(&:place) %>
                      <% if places.any? %>
                        <% places.each do |place| %><div><strong><%= place.name %></strong></div><% end %>
                      <% else %>
                        <span class="text-muted">Aucune activité sélectionnée</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            <% end %>
          <% end %>

          <tr><td colspan="2" class="text-center fw-bold py-2 bg-light" style="border-bottom: 1px solid #000;">Transports</td></tr>
          <tr style="border-bottom: 1px solid #000;">
            <td class="fw-bold px-4" style="border-right: 1px solid #000;">Transports dans le Pays</td>
            <td class="px-4">
              <% if @trip.transport %>
                <div><strong><%= @trip.transport.transport_type %></strong></div>
              <% else %>
                <span class="text-muted">Aucun transport sélectionné</span>
              <% end %>
            </td>
          </tr>
          <tr style="border-bottom: 1px solid #000;">
            <td class="fw-bold px-4" style="border-right: 1px solid #000;">Transports dans les Villes</td>
            <td class="px-4">
              <% if @trip.transport %>
                <div><strong><%= @trip.transport.transport_type %></strong></div>
              <% else %>
                <span class="text-muted">Aucun transport sélectionné</span>
              <% end %>
            </td>
          </tr>

        </tbody>
      </table>
    </div>
  </div>
</div>
