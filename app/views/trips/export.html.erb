<div class="container-fluid px-5 py-5">
  <div class="mb-5">
    <h1 class="display-4 fw-bold mb-3" style="color: #070485;">Le récapitulatif complet</h1>
    <p class="text-dark w-100" style="line-height: 1.6; font-size: 1.1rem;">
      Le récapitulatif complet est la page de synthèse qui permet de visualiser l'ensemble de l'aventure que vous avez construite.
      Cet outil est conçu pour offrir une maîtrise totale de votre itinéraire avant le départ.
    </p>
  </div>

  <div class="card shadow-sm" style="border: 1px solid #000;">
    <div class="card-header bg-white text-center py-4" style="border-bottom: 1px solid #000;">
      <h2 class="fw-bold mb-0" style="color: #000;">Résumé du voyage</h2>
    </div>

    <div class="card-body p-0">
      <table class="table table-bordered mb-0 align-middle" style="border: 1px solid #000; border-collapse: collapse; width: 100%;">
        <tbody>

          <%# --- SECTION VOLS --- %>
          <tr style="border-bottom: 1px solid #000;">
            <td class="fw-bold px-4" style="width: 25%; border-right: 1px solid #000;">Les vols pour rendre en Égypte</td>
            <td class="px-4" style="width: 75%;">
              <% if @trip.flight %>
                <div>
                  <strong><%= @trip.flight.company %></strong> — Aller : <%= @trip.flight.take_off_at %> → <%= @trip.flight.land_at %>
                  <% if @trip.flight.stopover.present? && !["", "0", "Direct"].include?(@trip.flight.stopover) %>
                    <span class="text-muted small">(<%= @trip.flight.stopover %>)</span>
                  <% else %>
                    <span class="text-muted small">(direct)</span>
                  <% end %>
                </div>
                <div>
                  <strong><%= @trip.flight.company_return %></strong> — Retour : <%= @trip.flight.take_off_at_return %> → <%= @trip.flight.land_at_return %>
                  <% if @trip.flight.stopover_return.present? && !["", "0", "Direct"].include?(@trip.flight.stopover_return) %>
                    <span class="text-muted small">(<%= @trip.flight.stopover_return %>)</span>
                  <% else %>
                    <span class="text-muted small">(direct)</span>
                  <% end %>
                </div>
              <% else %>
                <span class="text-muted">Aucun vol sélectionné</span>
              <% end %>
            </td>
          </tr>

          <%# --- SECTION CAPITALE --- %>
          <% capitale = @trip.destination.categories.find_by(name: "La Capitale et les marchés traditionnels") %>
          <tr style="border-bottom: 1px solid #000;">
            <td class="fw-bold px-4" style="border-right: 1px solid #000;">La Capitale et les marchés traditionnels</td>
            <td class="px-4">
              <% if capitale %>
                <% places = @trip.bookmarks.joins(:place).where(places: { category_id: capitale.id }).map(&:place) %>
                <% if places.any? %>
                  <% places.each do |place| %>
                    <div><strong><%= place.name %></strong></div>
                  <% end %>
                <% else %>
                  <span class="text-muted">Aucun lieu sélectionné</span>
                <% end %>
              <% end %>
            </td>
          </tr>

          <%# --- AUTRES VILLES --- %>
          <% cat_villes = @trip.destination.categories.find_by(name: "Les autres Villes") %>
          <tr><td colspan="2" class="text-center fw-bold py-2 bg-light" style="border-bottom: 1px solid #000;">Les autres Villes</td></tr>
          <% ["Alexandrie", "Assouan", "Luxor"].each do |ville| %>
            <tr style="border-bottom: 1px solid #000;">
              <td class="px-4" style="border-right: 1px solid #000;"><strong><%= ville %></strong></td>
              <td class="px-4">
                <% if cat_villes %>
                  <% places = @trip.bookmarks.joins(:place).where(places: { category_id: cat_villes.id, sub_category: "Les activités à faire à #{ville}" }).map(&:place) %>
                  <% if places.any? %>
                    <% places.each do |place| %>
                      <div><strong><%= place.name %></strong></div>
                    <% end %>
                  <% else %>
                    <span class="text-muted">Aucun lieu sélectionné</span>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>

          <%# --- STATIONS BALNÉAIRES --- %>
          <% cat_balneaires = @trip.destination.categories.find_by(name: "Les Stations Balnéaires") %>
          <tr><td colspan="2" class="text-center fw-bold py-2 bg-light" style="border-bottom: 1px solid #000;">Les Stations Balnéaires</td></tr>
          <% ["Sharm el-Sheikh", "Marsa Matrouch", "Hurghada", "Marsa alam", "Taba", "Nuweiba"].each do |station| %>
            <tr style="border-bottom: 1px solid #000;">
              <td class="px-4" style="border-right: 1px solid #000;"><strong><%= station %></strong></td>
              <td class="px-4">
                <% if cat_balneaires %>
                  <% places = @trip.bookmarks.joins(:place).where(places: { category_id: cat_balneaires.id, sub_category: "Les activités à faire à #{station}" }).map(&:place) %>
                  <% if places.any? %>
                    <% places.each do |place| %>
                      <div><strong><%= place.name %></strong></div>
                    <% end %>
                  <% else %>
                    <span class="text-muted">Aucun lieu sélectionné</span>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>

          <%# --- HORS CIRCUITS --- %>
          <tr><td colspan="2" class="text-center fw-bold py-2 bg-light" style="border-bottom: 1px solid #000;">Les Hors circuits</td></tr>
          <% ["Fayoum", "Le village nubiens", "Oasis"].each do |hc| %>
            <tr style="border-bottom: 1px solid #000;">
              <td class="px-4" style="border-right: 1px solid #000;"><strong><%= hc %></strong></td>
              <td class="px-4"></td>
            </tr>
          <% end %>

          <%# --- DÉSERTS ET NIL --- %>
          <tr><td colspan="2" class="text-center fw-bold py-2 bg-light" style="border-bottom: 1px solid #000;">Les déserts et le Nil</td></tr>
          <tr style="border-bottom: 1px solid #000;">
            <td class="px-4" style="border-right: 1px solid #000;"><strong>Les déserts</strong></td>
            <td class="px-4"></td>
          </tr>
          <tr style="border-bottom: 1px solid #000;">
            <td class="px-4" style="border-right: 1px solid #000;"><strong>Le Nil</strong></td>
            <td class="px-4"></td>
          </tr>

          <%# --- TRANSPORTS --- %>
          <tr style="border-bottom: 1px solid #000;">
            <td class="fw-bold px-4" style="border-right: 1px solid #000;">Transports dans le Pays</td>
            <td class="px-4"></td>
          </tr>
          <tr style="border-bottom: 1px solid #000;">
            <td class="fw-bold px-4" style="border-right: 1px solid #000;">Transports dans les Villes</td>
            <td class="px-4"></td>
          </tr>

        </tbody>
      </table>
    </div>
  </div>
</div>
