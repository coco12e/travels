<div class="container-fluid px-5 py-5">
  <div class="mb-5">
    <h1 class="display-4 fw-bold mb-3" style="color: #070485;">Le récapitulatif complet</h1>
    <p class="text-dark w-100 lh-lg fs-5">
      Le récapitulatif complet est la page de synthèse qui permet de visualiser l'ensemble de l'aventure que vous avez construite.
      Cet outil est conçu pour offrir une maîtrise totale de votre itinéraire avant le départ.
    </p>
  </div>

  <div class="card shadow-sm border border-dark">
    <div class="card-header bg-white text-center py-4 border-bottom border-dark">
      <h2 class="fw-bold mb-0 text-dark">Résumé du voyage</h2>
    </div>

    <div class="card-body p-0">
      <table class="table table-bordered mb-0 align-middle">
        <tbody>

          <tr class="border-bottom border-dark">
            <td class="fw-bold px-4 border-end border-dark" style="width: 25%;">Les vols pour se rendre en Égypte</td>
            <td class="px-4" style="width: 75%;">
              <% if @trip.flight %>
                <div>
                  <strong><%= @trip.flight.company %></strong> — Aller : <%= @trip.flight.take_off_at %> → <%= @trip.flight.land_at %>
                  <span class="text-muted small">(<%= @trip.flight.stopover.present? ? @trip.flight.stopover : "direct" %>)</span>
                </div>
                <div>
                  <strong><%= @trip.flight.company_return %></strong> — Retour : <%= @trip.flight.take_off_at_return %> → <%= @trip.flight.land_at_return %>
                  <span class="text-muted small">(<%= @trip.flight.stopover_return.present? ? @trip.flight.stopover_return : "direct" %>)</span>
                </div>
              <% else %>
                <span class="text-muted">Aucun vol sélectionné</span>
              <% end %>
            </td>
          </tr>

          <% @sub_categories_by_category.each do |category, sub_cat_names| %>
            <tr>
              <td colspan="2" class="text-center fw-bold py-2 bg-light border-bottom border-dark"><%= category.name %></td>
            </tr>
            <% if sub_cat_names.empty? %>
              <tr class="border-bottom border-dark">
                <td class="fw-bold px-4 border-end border-dark">Activités</td>
                <td class="px-4">
                  <% (@bookmarks_by_category[category] || []).each do |place| %>
                    <div><strong><%= place.name %></strong></div>
                  <% end %>
                  <% if (@bookmarks_by_category[category] || []).empty? %>
                    <span class="text-muted">Aucune activité sélectionnée</span>
                  <% end %>
                </td>
              </tr>
            <% else %>
              <% sub_cat_names.each do |sub_cat_name| %>
                <tr class="border-bottom border-dark">
                  <td class="px-4 border-end border-dark"><strong><%= sub_cat_name %></strong></td>
                  <td class="px-4">
                    <% places = (@bookmarks_by_category[category] || []).select { |p| p.sub_category == sub_cat_name } %>
                    <% if places.any? %>
                      <% places.each do |place| %><div><strong><%= place.name %></strong></div><% end %>
                    <% else %>
                      <span class="text-muted">Aucune activité sélectionnée</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          <% end %>

          <tr>
            <td colspan="2" class="text-center fw-bold py-2 bg-light border-bottom border-dark">Transports</td>
          </tr>

          <tr class="border-bottom border-dark">
            <td class="fw-bold px-4 border-end border-dark">Transports dans le Pays</td>
            <td class="px-4">
              <% if @trip.transport %>
                <div><strong><%= @trip.transport.transport_type %></strong></div>
              <% else %>
                <span class="text-muted">Aucun transport sélectionné</span>
              <% end %>
            </td>
          </tr>

          <tr class="border-bottom border-dark">
            <td class="fw-bold px-4 border-end border-dark">Transports dans les Villes</td>
            <td class="px-4">
              <% if @trip.transport %>
                <div><strong><%= @trip.transport.transport_type %></strong></div>
              <% else %>
                <span class="text-muted">Aucun transport sélectionné</span>
              <% end %>
            </td>
          </tr>

        </tbody>
      </table>
    </div>
  </div>
</div>
