<div class="container-fluid px-5 py-5">
  <div class="mb-5">
    <h1 class="display-4 fw-bold mb-2" style="color: #070485;">Les catégories</h1>
    <h2 class="h4 fw-normal" style="color: #019dbd;">
      L'application est structurée en six piliers majeurs pour permettre une navigation intuitive et une planification personnalisée.
    </h2>
  </div>

  <div class="row g-4">
    <% @categories.each do |category| %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm bg-white overflow-hidden h-100" style="border-radius: 12px;">

          <div class="ratio ratio-16x9 bg-light">
            <% if category.photo_url.present? %>
              <img src="/<%= URI.encode_www_form_component(category.photo_url) %>"
                   class="card-img-top object-fit-cover"
                   alt="<%= category.name %>">
            <% else %>
              <div class="d-flex align-items-center justify-content-center h-100">
                <i class="fa-solid fa-image text-secondary fs-1"></i>
              </div>
            <% end %>
          </div>

          <div class="card-body d-flex flex-column p-3">
            <h5 class="card-title fw-bold m-0" style="color: #070485;">
              <%= category.name %>
            </h5>

            <div class="mt-auto pt-3 d-flex justify-content-end">
              <%= link_to "Sélectionner", places_trip_path(@trip, category_id: category.id),
                    class: "btn px-4 fw-bold shadow-sm text-white",
                    style: "background-color: #d35400; border: none; border-radius: 5px;" %>
            </div>
          </div>

        </div>
      </div>
    <% end %>
  </div>
</div>
