<%= render "shared/stepper", current_step: 9 %>

<div class="container-fluid px-5 py-5">
  <div class="mb-5">
    <h1 class="display-4 fw-bold mb-3" style="color: #070485;">Le récapitulatif complet</h1>
    <p class="text-dark w-100 lh-lg fs-5">
      Le récapitulatif complet est la page de synthèse qui permet de visualiser l'ensemble de l'aventure que vous avez construite.
      Cet outil est conçu pour offrir une maîtrise totale de votre itinéraire avant le départ.
    </p>
  </div>

  <div class="card shadow-sm border border-dark">
    <div class="card-body p-0">
      <table class="table table-bordered mb-0 align-middle">
        <tbody>

          <%# ---- SECTION VOLS ---- %>
          <tr>
            <td colspan="3" class="text-center fw-bold py-2 border-bottom border-dark" style="background-color: #f8f9fa;">
              <span style="color: #070485; font-size: 1.15rem;">Les vols</span>
            </td>
          </tr>

          <tr class="border-bottom border-dark">
            <td class="fw-bold px-4 border-end border-dark" style="width: 25%; color: #070485; font-size: 1.05rem;">Les vols pour se rendre en Égypte</td>
            <td class="px-4 border-end border-dark" style="width: 55%;">
              <% if @trip.flight %>
                <div>
                  <strong><%= @trip.flight.company %></strong> — Aller : <%= @trip.flight.take_off_at %> → <%= @trip.flight.land_at %>
                  <span class="text-muted small">(<%= @trip.flight.stopover.present? ? @trip.flight.stopover : "direct" %>)</span>
                </div>
                <div>
                  <strong><%= @trip.flight.company_return %></strong> — Retour : <%= @trip.flight.take_off_at_return %> → <%= @trip.flight.land_at_return %>
                  <span class="text-muted small">(<%= @trip.flight.stopover_return.present? ? @trip.flight.stopover_return : "direct" %>)</span>
                </div>
              <% else %>
                <span class="text-muted">Aucun vol sélectionné</span>
              <% end %>
            </td>
            <td class="text-center" style="width: 20%;">
              <%= link_to "Modifier", trip_flights_path(@trip, return_to: "show"), class: "btn px-4 py-2 fw-bold text-white border-0 rounded-2", style: "background-color: #d35400; width: 140px;" unless @trip.confirmed? %>
            </td>
          </tr>

          <%# ---- SECTIONS CATÉGORIES ---- %>
          <% @sub_categories_by_category.reject { |cat, _| cat.name == "Les plats typiques" }.each do |category, sub_cat_names| %>
            <tr>
              <td colspan="3" class="text-center fw-bold py-2 bg-light border-bottom border-dark">
                <span style="color: #070485; font-size: 1.15rem;"><%= category.name %></span>
              </td>
            </tr>
            <% effective_sub_cats = category.name == "Les déserts et le Nil" ? ["Les déserts : lieux à découvrir", "Le Nil : Croisière sur le Nil"] : sub_cat_names %>
            <% if effective_sub_cats.empty? %>
              <tr class="border-bottom border-dark">
                <td class="fw-bold px-4 border-end border-dark" style="color: #070485; font-size: 1.05rem;">Activités</td>
                <td class="px-4 border-end border-dark">
                  <% places = @bookmarks_by_category[category] || [] %>
                  <% if places.any? %>
                    <% places.each do |place| %><div><strong><%= place.name %></strong></div><% end %>
                  <% else %>
                    <span class="text-muted">Aucune activité sélectionnée</span>
                  <% end %>
                </td>
                <td class="text-center">
                  <%= link_to "Modifier", trip_category_places_path(@trip, category, return_to: "show"), class: "btn px-4 py-2 fw-bold text-white border-0 rounded-2", style: "background-color: #d35400; width: 140px;" unless @trip.confirmed? %>
                </td>
              </tr>
            <% else %>
              <% effective_sub_cats.each do |sub_cat_name| %>
                <tr class="border-bottom border-dark">
                  <td class="px-4 border-end border-dark" style="color: #070485; font-size: 1.05rem;"><strong><%= sub_cat_name %></strong></td>
                  <td class="px-4 border-end border-dark">
                    <% places = (@bookmarks_by_category[category] || []).select { |p| p.sub_category == sub_cat_name } %>
                    <% if places.any? %>
                      <% places.each do |place| %><div><strong><%= place.name %></strong></div><% end %>
                    <% else %>
                      <span class="text-muted">Aucune activité sélectionnée</span>
                    <% end %>
                  </td>
                  <td class="text-center">
                    <%= link_to "Modifier", trip_category_places_path(@trip, category, return_to: "show"), class: "btn px-4 py-2 fw-bold text-white border-0 rounded-2", style: "background-color: #d35400; width: 140px;" unless @trip.confirmed? %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          <% end %>

          <%# ---- SECTION TRANSPORTS ---- %>
          <tr>
            <td colspan="3" class="text-center fw-bold py-2 bg-light border-bottom border-dark">
              <span style="color: #070485; font-size: 1.15rem;">Transports</span>
            </td>
          </tr>

          <tr class="border-bottom border-dark">
            <td class="fw-bold px-4 border-end border-dark" style="color: #070485; font-size: 1.05rem;">Transports dans le Pays</td>
            <td class="px-4 border-end border-dark">
              <% pays = @trip.transports.where(transport_type: "pays") %>
              <% if pays.any? %>
                <% pays.each do |t| %><div><strong><%= t.name %></strong></div><% end %>
              <% else %>
                <span class="text-muted">Aucun transport sélectionné</span>
              <% end %>
            </td>
            <td class="text-center">
              <%= link_to "Modifier", trip_transports_path(@trip, return_to: "show"), class: "btn px-4 py-2 fw-bold text-white border-0 rounded-2", style: "background-color: #d35400; width: 140px;" unless @trip.confirmed? %>
            </td>
          </tr>

          <tr class="border-bottom border-dark">
            <td class="fw-bold px-4 border-end border-dark" style="color: #070485; font-size: 1.05rem;">Transports dans les Villes</td>
            <td class="px-4 border-end border-dark">
              <% villes = @trip.transports.where(transport_type: "villes") %>
              <% if villes.any? %>
                <% villes.each do |t| %><div><strong><%= t.name %></strong></div><% end %>
              <% else %>
                <span class="text-muted">Aucun transport sélectionné</span>
              <% end %>
            </td>
            <td class="text-center">
              <%= link_to "Modifier", trip_transports_path(@trip, return_to: "show"), class: "btn px-4 py-2 fw-bold text-white border-0 rounded-2", style: "background-color: #d35400; width: 140px;" unless @trip.confirmed? %>
            </td>
          </tr>

          <%# ---- BOUTON CONFIRMATION ---- %>
          <tr>
            <td colspan="3" class="px-4 py-4 text-center">
              <% if @trip.confirmed? %>
                <%= button_to "Modifier le voyage", confirm_trip_path(@trip, unconfirm: true), method: :patch, class: "btn btn-dark fw-bold py-3 fs-5", style: "width: 100%;" %>
              <% else %>
                <%= button_to "Confirmer mon itinéraire", confirm_trip_path(@trip), method: :patch, class: "btn fw-bold text-white fs-5 border-0 rounded-2 py-3", style: "background-color: #d35400; width: 100%;" %>
              <% end %>
            </td>
          </tr>

        </tbody>
      </table>
    </div>
  </div>

  <div class="text-end mt-4">
    <% if @trip.confirmed? %>
      <%= link_to "Exporter en PDF", export_trip_path(@trip), target: "_blank", class: "btn btn-outline-dark fw-bold" %>
    <% else %>
      <button class="btn btn-outline-secondary fw-bold" disabled title="Confirmez votre itinéraire avant d'exporter">Exporter en PDF</button>
    <% end %>
  </div>
</div>
